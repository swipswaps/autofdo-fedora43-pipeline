# benchmark_config.env
# Sourced by bench/benchmark_runner.sh — do NOT add a shebang line.
# All variables here override defaults defined in benchmark_runner.sh.

# Number of repeated perf stat runs (mean + stddev reported).
BENCH_REPEATS=7

# CPU core to pin the workload to (taskset -c).
# Set to "" to disable pinning (required on single-core VMs).
BENCH_CPU_CORE=2

# Disable CPU boost/turbo during benchmarks for more stable numbers.
# "auto"  — detect platform and disable if supported
# "true"  — always attempt to disable (errors if unsupported)
# "false" — never disable
BENCH_DISABLE_TURBO=auto

# perf hardware events to collect (one per line; blank lines ignored).
# These map to -e flags on perf stat.
BENCH_PERF_EVENTS="
cycles
instructions
branch-misses
L1-icache-load-misses
iTLB-load-misses
LLC-load-misses
"
